<div class="aztec-durability-summary" style="font-size: 0.9em; display: flex; flex-direction: column; gap: 10px;">
    
    <div style="display: flex; align-items: center; justify-content: space-between;">
        <span style="display: flex; align-items: center; gap: 5px;">
            <label style="font-weight: bold;">{{localize "pf2e-aztecs-sundered.sheet-text.hp"}}:</label>
            <input type="number" id="dur-curr-hp" value="{{currentHp}}" style="width: 50px; text-align: center;"> / 
            <input type="number" id="dur-max-hp" value="{{maxHp}}" style="width: 50px; text-align: center;">
        </span>
        {{#if isTracked}}
<span style="display: flex; gap: 10px;">
            <a data-action="sunder" title="{{localize "pf2e-aztecs-sundered.sheet-text.sunder-item"}}" style="cursor: pointer; font-weight: bold; color: #d9534f;">
                <i class="fa-solid fa-hammer-crash"></i> {{localize "pf2e-aztecs-sundered.sheet-text.sunder"}}
            </a>
            <a data-action="repair" title="{{localize "pf2e-aztecs-sundered.sheet-text.repair-item"}}" style="cursor: pointer;
font-weight: bold; color: #5bc0de;">
                <i class="fa-solid fa-wrench"></i> {{localize "pf2e-aztecs-sundered.sheet-text.repair"}}
            </a>
        </span>
        {{/if}}
    </div>
    
    <div style="display: flex; align-items: center; justify-content: space-between;">
        <span style="display: flex; align-items: center; gap: 5px;">
            <label style="font-weight: bold;">{{localize "pf2e-aztecs-sundered.sheet-text.hardness"}}:</label>
            <input type="number" id="dur-hd" value="{{hardness}}" style="width: 50px; text-align: center;">
            <span style="color: #666;">({{localize "pf2e-aztecs-sundered.sheet-text.bt-short"}}: <span id="dur-bt">{{bt}}</span>)</span>
        </span>
    </div>
    
    <div class="form-group" style="display: flex; flex-direction: column; gap: 5px;">
        <label style="font-weight: bold;">{{localize "pf2e-aztecs-sundered.dialog.material.title"}}</label>
        <select id="dur-mat-select" style="width: 100%;">
            <option value="">{{localize "pf2e-aztecs-sundered.dialog.material.none"}}</option>
            {{#each materialOptions}}
                <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
            {{/each}}
        </select>
    </div>

    <details style="margin-top: 10px; padding: 8px; border: 1px solid var(--color-border-light); border-radius: 4px; background: rgba(0,0,0,0.03);">
        <summary style="font-weight: bold;
cursor: pointer;">{{localize "pf2e-aztecs-sundered.dialog.durability.iwr"}}</summary>
        
        <div style="margin-top: 10px;">
<label style="font-size: 0.9em;
font-weight: bold;">{{localize "pf2e-aztecs-sundered.dialog.durability.immunities"}}</label>
            <select id="dur-add-immunity" style="width: 100%;
margin-bottom: 5px;">
                <option value="">{{localize "pf2e-aztecs-sundered.dialog.durability.select-immunity"}}</option>
                {{#each immunityOptions}}
                <option value="{{this.key}}">{{this.label}}</option>
                {{/each}}
            </select>
            <div id="dur-immunities-list" style="display: flex; flex-direction: column; gap: 4px;">
                {{#each immunities}}
                <div class="iwr-row immunity-row" data-type="{{this.type}}" style="display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.1); padding: 4px 8px; border-radius: 3px; font-size: 0.9em;">
                    <span>{{this.label}}</span>
                    <a class="remove-iwr" style="color: #d9534f; cursor: pointer;"><i class="fa-solid fa-trash"></i></a>
                </div>
                {{/each}}
            </div>
        </div>

        <div style="margin-top: 10px;">
<label style="font-size: 0.9em;
font-weight: bold;">{{localize "pf2e-aztecs-sundered.dialog.durability.weaknesses"}}</label>
            <select id="dur-add-weakness" style="width: 100%;
margin-bottom: 5px;">
                <option value="">{{localize "pf2e-aztecs-sundered.dialog.durability.select-weakness"}}</option>
                {{#each weaknessOptions}}
                <option value="{{this.key}}">{{this.label}}</option>
                {{/each}}
            </select>
            <div id="dur-weaknesses-list" style="display: flex; flex-direction: column; gap: 4px;">
                {{#each weaknesses}}
                <div class="iwr-row weakness-row" data-type="{{this.type}}" style="display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.1); padding: 4px 8px; border-radius: 3px; font-size: 0.9em;">
                    <span>{{this.label}}</span>
                    <span style="display: flex; align-items: center; gap: 6px;">
                        <input type="number" class="iwr-value" value="{{this.value}}" style="width: 45px; height: 22px; text-align: center;">
                        <a class="remove-iwr" style="color: #d9534f; cursor: pointer;"><i class="fa-solid fa-trash"></i></a>
                    </span>
                </div>
                {{/each}}
            </div>
        </div>

        <div style="margin-top: 10px;">
<label style="font-size: 0.9em;
font-weight: bold;">{{localize "pf2e-aztecs-sundered.dialog.durability.resistances"}}</label>
            <select id="dur-add-resistance" style="width: 100%;
margin-bottom: 5px;">
                <option value="">{{localize "pf2e-aztecs-sundered.dialog.durability.select-resistance"}}</option>
                {{#each resistanceOptions}}
                <option value="{{this.key}}">{{this.label}}</option>
                {{/each}}
            </select>
            <div id="dur-resistances-list" style="display: flex; flex-direction: column; gap: 4px;">
                {{#each resistances}}
                <div class="iwr-row resistance-row" data-type="{{this.type}}" style="display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.1); padding: 4px 8px; border-radius: 3px; font-size: 0.9em;">
                    <span>{{this.label}}</span>
                    <span style="display: flex; align-items: center; gap: 6px;">
                        <input type="number" class="iwr-value" value="{{this.value}}" style="width: 45px; height: 22px; text-align: center;">
                        <a class="remove-iwr" style="color: #d9534f; cursor: pointer;"><i class="fa-solid fa-trash"></i></a>
                    </span>
                </div>
                {{/each}}
            </div>
        </div>
    </details>
</div>