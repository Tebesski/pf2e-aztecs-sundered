<div style="display: flex; flex-direction: column; gap: 10px;">
   <div style="text-align: center; margin-bottom: 5px;">
      {{localize "pf2e-aztecs-sundered.dialog.repair.repairing"}}
      <strong>{{item.name}}</strong>
   </div>
   <div class="form-group">
      <label>{{localize
            "pf2e-aztecs-sundered.dialog.repair.crafting-proficiency"
         }}</label>
      <input type="text" value="{{rankName}}" disabled />
   </div>
   <div class="form-group">
      <label>{{localize "pf2e-aztecs-sundered.dialog.repair.repair-dc"}}</label>
      <input type="number" id="repair-dc" value="{{dc}}" />
   </div>
   <hr />
   <div style="text-align: center; font-size: 0.9em; color: gray;">
      {{localize
         "pf2e-aztecs-sundered.dialog.repair.restores-info"
         baseHeal=baseHeal
         critHeal=critHeal
      }}
   </div>
</div>